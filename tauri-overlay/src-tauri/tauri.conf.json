{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../",
    "distDir": "../"
  },
  "package": {
    "productName": "Wasted Token Overlay",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true
      }
    },
    "bundle": {
      "active": false,
      "identifier": "co.mybati.wasted-token-overlay",
      "icon": ["icons/icon.png", "icons/32x32.png", "icons/128x128.png", "icons/256x256.png"]
    },
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:3777; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "label": "overlay",
        "title": "",
        "width": 320,
        "height": 250,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false
      }
    ]
  }
}
