{
  "name": "ag-code-token",
  "version": "1.3.0",
  "description": "Universal AI coding token usage monitor — track costs across Claude Code, Codex, Cursor, Windsurf, Cline, Copilot, Continue.dev, Aider, and Antigravity from a single dashboard",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./server": "./server.js",
    "./models": "./models.js",
    "./parser": "./parser.js",
    "./budget": "./budget.js",
    "./webhooks": "./webhooks.js",
    "./currency": "./currency.js"
  },
  "bin": {
    "ag-token": "./cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "tray": "node cli.js tray",
    "lint": "node --check server.js && node --check models.js && node --check parser.js && node --check security.js && node --check budget.js && node --check webhooks.js && node --check currency.js",
    "docker:build": "docker build -t ag-code-token .",
    "docker:run": "docker compose up -d"
  },
  "keywords": [
    "ai-coding",
    "token-usage",
    "cost-tracking",
    "budget-alerts",
    "multi-currency",
    "webhooks",
    "slack",
    "discord",
    "telegram",
    "claude-code",
    "codex",
    "cursor",
    "windsurf",
    "cline",
    "copilot",
    "aider",
    "antigravity",
    "observability",
    "llm",
    "dashboard",
    "docker"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuckuola619/wasted-token-tracker.git"
  },
  "homepage": "https://github.com/vuckuola619/wasted-token-tracker#readme",
  "bugs": {
    "url": "https://github.com/vuckuola619/wasted-token-tracker/issues"
  },
  "files": [
    "index.js",
    "server.js",
    "cli.js",
    "models.js",
    "parser.js",
    "security.js",
    "watcher.js",
    "budget.js",
    "webhooks.js",
    "currency.js",
    "sql_scanner.js",
    "providers/",
    "public/",
    "tray/"
  ],
  "author": "vuckuola619",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
